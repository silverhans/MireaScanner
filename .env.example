BOT_TOKEN=your_telegram_bot_token_here
WEBAPP_URL=https://your-domain.com
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
# In production behind Nginx, bind API to localhost.
# For Docker/local, you can leave it unset (default 0.0.0.0) or set to 0.0.0.0.
API_BIND_HOST=127.0.0.1
API_PORT=8080

# Optional: HTTP proxy for all requests to MIREA (mobile IP).
# Format: http://user:pass@host:port
# MIREA_PROXY=http://user:pass@host:port

# Secret(s) for encrypting user sessions in the DB. Recommended: random 32+ bytes.
# For rotation, provide multiple comma-separated values; first is used for encryption.
SESSION_KEYS=your_random_secret_1,your_previous_secret_2

# Secret key for JWT tokens.
JWT_SECRET=your_random_jwt_secret_here

# Redis URL for shared throttle and session cache.
# Required for multi-worker mode (WORKER_COUNT > 1). Single-worker can leave this unset.
# REDIS_URL=redis://localhost:6379/0

# Number of aiohttp worker processes. Requires Redis if > 1.
WORKER_COUNT=1

# Attendance peak protection (global throttle)
ATTENDANCE_MAX_CONCURRENT=60
ATTENDANCE_MAX_RPS=25
ATTENDANCE_QUEUE_TIMEOUT_S=55
ATTENDANCE_PER_REQUEST_CONCURRENT=5

# Optional Rust attendance core (for attendance cap estimation in BRS).
# Safe defaults keep Python as primary path.
ATTENDANCE_CORE_ENABLED=false
ATTENDANCE_CORE_SHADOW=true
ATTENDANCE_CORE_BIN=./attendance_core/target/release/attendance_core
ATTENDANCE_CORE_TIMEOUT_S=1.2

# Optional C++ modules (compiled binaries for performance-critical paths).
# Build instructions: see uuid_core/, zone_core/, protobuf_core/ directories.
PROTOBUF_CORE_ENABLED=false
PROTOBUF_CORE_BIN=./protobuf_core/protobuf_core
PROTOBUF_CORE_TIMEOUT_S=0.5

UUID_CORE_ENABLED=false
UUID_CORE_BIN=./uuid_core/uuid_core
UUID_CORE_TIMEOUT_S=0.5

ZONE_CORE_ENABLED=false
ZONE_CORE_BIN=./zone_core/zone_core
ZONE_CORE_TIMEOUT_S=0.8

# Optional token for accessing internal health details.
# If unset, /api/health/details is disabled (404).
# HEALTH_DETAILS_TOKEN=your_random_health_token_here

# Feature flags (kill-switches) for external modules.
FEATURE_GRADES_ENABLED=true
FEATURE_ACS_ENABLED=true
FEATURE_SCHEDULE_ENABLED=true
